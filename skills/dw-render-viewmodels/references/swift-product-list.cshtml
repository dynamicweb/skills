@inherits ViewModelTemplate<ProductListViewModel>
@using Dynamicweb.Rendering
@using Dynamicweb.Ecommerce.ProductCatalog

@{
    var productList = Model.Products ?? new List<ProductViewModel>();
}

@if (productList.Count > 0)
{
    <div class="product-list">
        <!-- Product table with facets -->
        <div class="row">
            <!-- Facet sidebar -->
            @if (Model.FacetGroups != null && Model.FacetGroups.Count > 0)
            {
                <div class="col-lg-3">
                    <div class="facets">
                        @foreach (var facetGroup in Model.FacetGroups)
                        {
                            @foreach (var facet in facetGroup.Facets)
                            {
                                <div class="facet-group border-bottom mb-3">
                                    <h5 class="mb-3">@facet.Name</h5>

                                    @foreach (var option in facet.Options)
                                    {
                                        string disabled = option.Count <= 0 ? "disabled" : string.Empty;

                                        @if (facet.RenderType == "Colors")
                                        {
                                            <div class="colorbox">
                                                <input type="checkbox" class="@disabled" name="@facet.QueryParameter" value="@option.Value" @(option.Selected ? "checked" : "") title="@option.Label">
                                                <span class="colorbox-background" style="background-color: @option.Value"></span>
                                            </div>
                                        }
                                        else
                                        {
                                            <label class="form-check mb-2" @disabled>
                                                <input type="checkbox" class="form-check-input" name="@facet.QueryParameter" value="@option.Value" @(option.Selected ? "checked" : "")>
                                                <span class="form-check-label">
                                                    @option.Label <small class="opacity-75">(@option.Count)</small>
                                                </span>
                                            </label>
                                        }
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            }

            <!-- Products -->
            <div class="@(Model.FacetGroups?.Count > 0 ? "col-lg-9" : "col-12")">
                <div class="row g-3">
                    @foreach (var product in productList)
                    {
                        <div class="col-sm-6 col-lg-4">
                            <div class="card h-100">
                                <img src="@product.DefaultImage" class="card-img-top" alt="@product.Name">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title h6">
                                        <a href="@product.GetProductLink(GetPageIdByNavigationTag("Shop"))">
                                            @product.Name @product.VariantName
                                        </a>
                                    </h5>

                                    @if (product.Price != null)
                                    {
                                        <div class="mt-auto">
                                            @if (product.HasDiscount())
                                            {
                                                <span class="text-decoration-line-through text-muted">
                                                    @product.PriceBeforeDiscount.Price.Formatted
                                                </span>
                                            }
                                            <div class="fs-5 fw-bold text-price">
                                                @product.Price.Price.Formatted
                                            </div>
                                            @if (product.Price.TryGetVatLabel(out string vatLabel))
                                            {
                                                <small class="text-muted">@Translate(vatLabel)</small>
                                            }
                                        </div>
                                    }

                                    @if (product.StockLevel <= 0 && !product.NeverOutOfstock)
                                    {
                                        <span class="badge bg-danger mt-2">@Translate("Out of Stock")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.PageCount > 1)
                {
                    <nav class="mt-5">
                        <ul class="pagination justify-content-center">
                            @for (int p = 1; p <= Model.PageCount; p++)
                            {
                                var isActive = p == Model.CurrentPage ? "active" : "";
                                <li class="page-item @isActive">
                                    <a class="page-link" href="?PageNum=@p">@p</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }

                <div class="text-center text-muted">
                    @Translate("Showing") @Model.PageSize @Translate("of") @Model.TotalProductsCount @Translate("products")
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        @Translate("No products found")
        @if (Model.SpellCheckerSuggestions?.Count > 0)
        {
            <div class="mt-2">
                @Translate("Did you mean"):
                @foreach (var suggestion in Model.SpellCheckerSuggestions)
                {
                    <a href="?q=@System.Net.WebUtility.UrlEncode(suggestion)">@suggestion</a>
                    @if (Model.SpellCheckerSuggestions.IndexOf(suggestion) < Model.SpellCheckerSuggestions.Count - 1)
                    {
                        <text>, </text>
                    }
                }
            </div>
        }
    </div>
}
